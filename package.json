{
  "name": "@anml-foundation/server",
  "version": "0.1.0",
  "description": "ANML 1.0 server SDK for Node.js/TypeScript — document builder, serialization, discovery, and validation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["anml", "agent", "agentic", "server", "markup", "machine-first", "duckument"],
  "author": "ANML Foundation",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ANML-Foundation/anml-server-node.git"
  },
  "homepage": "https://anmlfoundation.org",
  "engines": { "node": ">=18.0.0" },
  "dependencies": {
    "fast-xml-parser": "4.5.1"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "typescript": "5.7.3",
    "vitest": "3.1.1"
  }
}
